NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nextax
# Em Supabase/produção use DIRECT_URL para migrate deploy. Em local pode repetir DATABASE_URL.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/nextax
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-com-32-caracteres-minimo
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-com-32-caracteres-minimo
WEB_ORIGIN=http://localhost:5173
WEB_ORIGINS=http://localhost:5173,https://www.nextax.business,https://nextax.business
RESET_PASSWORD_URL=http://localhost:5173/reset-password

# E-mail transacional para verificação de e-mail e recuperação de senha (Resend)
# Obrigatório em produção quando o cadastro direto estiver ativo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=NexTax <no-reply@nextax.business>
NEXCORE_APP_URL=https://www.nexcore.business/app
NEXCORE_API_URL=https://api.nexcore.business/api
NEXCORE_PRODUCT_KEY=mesma-chave-cadastrada-no-nexcore-para-nextax
NEXCORE_INTERNAL_API_KEY=chave-interna-para-retornar-ao-nexcore
NEXTAX_INTERNAL_API_KEY=chave-interna-para-crons-e-manutencao-do-nextax
NEXFINANCE_APP_URL=https://www.nexfinance.business
NEXSTOCK_APP_URL=https://www.nexstock.business
NEXCRM_APP_URL=https://www.nexcrm.business

# Supabase Storage privado para documentos fiscais
# Use a Service Role Key somente na API/Render. Nunca coloque essa chave no front/Vercel.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-do-supabase
SUPABASE_STORAGE_BUCKET=nextax-documents
SUPABASE_SIGNED_URL_EXPIRES_IN=600

# Mercado Pago Checkout Pro
# Crie as credenciais no painel do Mercado Pago e coloque as variáveis reais no Render.
API_PUBLIC_URL=https://api.nextax.business
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-ou-TEST-seu-access-token
MERCADO_PAGO_PUBLIC_KEY=APP_USR-ou-TEST-sua-public-key
# Obrigatório em produção quando MERCADO_PAGO_ACCESS_TOKEN estiver configurado.
MERCADO_PAGO_WEBHOOK_SECRET=seu-webhook-secret
MERCADO_PAGO_SUCCESS_URL=https://www.nextax.business/?billing=success
MERCADO_PAGO_FAILURE_URL=https://www.nextax.business/?billing=failure
MERCADO_PAGO_PENDING_URL=https://www.nextax.business/?billing=pending
MERCADO_PAGO_STATEMENT_DESCRIPTOR=NEXTAX

# Preços mensais em BRL. Ajuste no Render sem mexer no código.
NEXTAX_PRICE_STARTER=29.90
NEXTAX_PRICE_PRO=59.90
NEXTAX_PRICE_BUSINESS=129.90
NEXTAX_ADDON_NEXFINANCE_PRICE=19.90
NEXTAX_ADDON_NEXSTOCK_PRICE=29.90
NEXTAX_ADDON_NEXCRM_PRICE=39.90
