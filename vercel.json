{
  "installCommand": "npm install --prefix apps/web --no-audit --no-fund --legacy-peer-deps",
  "buildCommand": "npm run build --prefix apps/web",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}